---
/**
 * WebSite構造化データ（JSON-LD）
 *
 * サイト全体の情報を検索エンジンに提供
 * Schema.org WebSite型を使用
 *
 * 用途:
 * - サイト全体の情報提供
 * - SEO強化
 */
import { SITE as globalText } from "@/config/site";

const siteBaseHref = (Astro.site?.href ?? globalText.url).replace(/\/$/, "");

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteBaseHref}/#website`,
  name: globalText.og.site_name,
  description: globalText.og.description,
  url: siteBaseHref,
  inLanguage: "ja-JP",

  // 運営者情報（Person）
  publisher: {
    "@type": "Person",
    "@id": `${siteBaseHref}/#person`,
    name: globalText.global.author,
    url: siteBaseHref,
  },

  // サイトのロゴ
  logo: {
    "@type": "ImageObject",
    url: `${siteBaseHref}/logo.svg`,
    width: "512",
    height: "512",
  },
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
