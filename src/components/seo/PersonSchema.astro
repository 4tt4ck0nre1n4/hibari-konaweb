---
/**
 * Person構造化データ（JSON-LD）
 *
 * 個人事業主としてのプロフィール情報をGoogleなどの検索エンジンに提供
 * Schema.org Person型を使用
 *
 * 用途:
 * - 検索結果でのリッチリザルト表示
 * - ナレッジグラフへの情報提供
 * - SEO強化
 */
import { SITE as globalText } from "@/config/site";

const siteBaseHref = (Astro.site?.href ?? globalText.url).replace(/\/$/, "");

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${siteBaseHref}/#person`,
  name: globalText.global.author,
  url: siteBaseHref,
  jobTitle: "Web Developer / Freelance Coder",
  description: globalText.og.description,

  // プロフィール画像
  image: globalText.og.image,

  // 所属組織（個人事業主として）
  worksFor: {
    "@type": "Organization",
    name: globalText.global.author,
  },

  // SNSリンク（実在する公開プロフィールのみを出力）
  sameAs: ["https://github.com/4tt4ck0nre1n4"],

  // 連絡先情報
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "customer support",
    url: `${siteBaseHref}/contact`,
    availableLanguage: "Japanese",
  },

  // スキルセット（知識領域）
  knowsAbout: [
    "Web Development",
    "Astro",
    "WordPress",
    "TypeScript",
    "JavaScript",
    "React",
    "HTML",
    "CSS",
    "Netlify",
    "Vite",
    "GSAP",
    "Responsive Design",
    "Web Accessibility",
    "SEO Optimization",
  ],

  // サービス詳細は /service の OfferCatalog を正とする
  hasOfferCatalog: {
    "@id": `${siteBaseHref}/service#offer-catalog`,
  },
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
