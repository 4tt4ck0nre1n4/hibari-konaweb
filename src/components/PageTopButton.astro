---
import pageTopImage from "../assets/svg/pageTopImage.svg";
import pageTopIcon from "../assets/svg/top.svg";
---

<button id="pageTopButton" class="page-top-button" aria-label="ページトップへ戻る">
  <!-- CLS改善: width/height属性を明示的に設定 -->
  <img src={pageTopImage.src} alt="" class="page-top-button__image" width="60" height="90" />
  <div class="page-top-button__textInner">
    <!-- CLS改善: width/height属性を明示的に設定 -->
    <img src={pageTopIcon.src} alt="" class="page-top-button__icon" width="16" height="16" />
    <span class="page-top-button__text">Page Top</span>
  </div>
</button>

<style>
  .page-top-button {
    min-width: 80px;
    min-height: 80px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    color: inherit;
    background: transparent;
    border: 2px solid currentColor;
    border-radius: 1rem;
    box-shadow: 0 8px 16px rgb(0 0 0 / 0.6);
    opacity: 0;
    visibility: hidden;
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    transform: translateY(1rem);
    transition:
      opacity 0.3s ease,
      visibility 0.3s ease,
      transform 0.3s ease,
      box-shadow 0.4s ease;
    z-index: 1000;
    padding-block: 0.5rem;
    padding-inline: 0.25rem;
  }

  .page-top-button.is-visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .page-top-button:is(:hover, :focus-visible) {
    box-shadow: 0 16px 8px rgb(0 0 0 / 0.6);
    transform: translateY(-0.25rem);
  }

  html.dark .page-top-button:is(:hover, :focus-visible) {
    box-shadow: 0 16px 8px rgb(255 255 255 / 0.6);
  }

  .page-top-button:active {
    transform: translateY(0);
    box-shadow: 0 4px 8px rgb(0 0 0 / 0.4);
  }

  .page-top-button__image {
    width: 60px;
    height: 90px;
    display: block;
    filter: drop-shadow(2px 4px 4px rgb(160 160 160 / 0.7));
    border-radius: 0.5rem;
    transition: transform 0.3s ease;
  }

  .page-top-button__textInner {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
  }

  .page-top-button__icon {
    width: 16px;
    height: 16px;
    display: block;
    background-color: var(--color-white);
    border-radius: 0.5rem;
    filter: drop-shadow(2px 4px 4px rgb(160 160 160 / 0.7));
    transition: transform 0.3s ease;
  }

  .page-top-button:is(:hover, :focus-visible) .page-top-button__icon {
    transform: scale(1.1);
  }

  .page-top-button__text {
    font-size: 0.75rem;
    font-weight: 600;
    text-align: center;
    white-space: nowrap;
  }

  /* タブレット・スマホサイズでのレスポンシブ対応 */
  @media (width <= 768px) {
    .page-top-button {
      bottom: 1.5rem;
      right: 1.5rem;
      padding: 0.75rem;
      min-width: 64px;
      min-height: 64px;
      gap: 0.25rem;
    }

    .page-top-button__icon {
      width: 14px;
      height: 14px;
    }
  }

  /* 超小型スマホサイズでの最適化 */
  @media (width <= 480px) {
    .page-top-button {
      bottom: 1rem;
      right: 1rem;
      padding: 0.5rem;
      min-width: 56px;
      min-height: 56px;
    }

    .page-top-button__icon {
      width: 12px;
      height: 12px;
    }
  }

  /* 印刷・PDF・お問い合わせ転送時は非表示 */
  @media print {
    .page-top-button {
      display: none !important;
      visibility: hidden !important;
      opacity: 0 !important;
      pointer-events: none !important;
    }

    .page-top-button__image,
    .page-top-button__textInner,
    .page-top-button__icon,
    .page-top-button__text {
      display: none !important;
      visibility: hidden !important;
      opacity: 0 !important;
    }
  }
</style>

<script>
  // @ts-nocheck
  // IIFEでスコープを分離（重複宣言エラーを防ぐ）
  (() => {
    // 開発環境でのみログを出力する関数（重複宣言を防ぐため、既存チェック）
    if (typeof window !== "undefined" && typeof window.devLog === "undefined") {
      window.devLog = (...args: unknown[]) => {
        if (window.__DEV__) {
          console.log("[PageTopButton]", ...args);
        }
      };
    }
    const devLog = typeof window !== "undefined" && window.devLog ? window.devLog : () => {};

    // グローバル変数でイベントリスナーを管理（重複登録を防ぐ）
    let scrollHandler: (() => void) | null = null;
    let clickHandler: (() => void) | null = null;
    let isInitialized = false;

    function cleanup() {
      devLog("🧹 Cleaning up event listeners");
      // 既存のイベントリスナーを削除
      if (scrollHandler) {
        window.removeEventListener("scroll", scrollHandler);
        scrollHandler = null;
      }
      if (clickHandler) {
        const pageTopButton = document.getElementById("pageTopButton");
        if (pageTopButton && clickHandler) {
          pageTopButton.removeEventListener("click", clickHandler);
          clickHandler = null;
        }
      }
      isInitialized = false;
    }

    function initPageTopButton() {
      const pageTopButton = document.getElementById("pageTopButton") as HTMLElement | null;
      if (!pageTopButton) {
        devLog("⚠️ PageTopButton element not found");
        return;
      }

      devLog("✅ Initializing PageTopButton");

      // 既に初期化されている場合はクリーンアップ
      if (isInitialized) {
        cleanup();
      }

      const firstView = document.querySelector(".fv") as HTMLElement | null;

      // FirstViewのbottom位置（ページトップからの距離）を取得
      // 強制リフローを避けるため、この関数はrequestAnimationFrame内で呼び出すこと
      function getFirstViewBottom(): number {
        if (!firstView) {
          // FirstViewがない場合は、一定のスクロール位置（300px）で表示
          devLog("ℹ️ FirstView not found, using 300px threshold");
          return 300;
        }

        // offsetTopとoffsetHeightを使用して、より確実にbottom位置を取得
        // 注意: offsetTopとoffsetHeightは強制リフローを引き起こすため、
        // この関数はrequestAnimationFrame内で呼び出す必要がある
        // getBoundingClientRect()の方が強制リフローを避けやすいが、
        // スクロール位置を考慮する必要があるため、offsetTop/offsetHeightを使用
        const offsetTop = firstView.offsetTop;
        const offsetHeight = firstView.offsetHeight;
        const bottom = offsetTop + offsetHeight;

        // キャッシュを使用して、同じフレーム内での複数回の呼び出しを避ける
        // 注意: スクロールやリサイズ時はキャッシュを無効化する必要がある

        devLog("📏 FirstView bottom position:", {
          offsetTop,
          offsetHeight,
          bottom,
          scrollY: window.scrollY || window.pageYOffset || document.documentElement.scrollTop,
        });

        return bottom;
      }

      // スクロールイベントハンドラー
      // 強制リフローを避けるため、requestAnimationFrame内でレイアウトプロパティを読み取る
      let rafId: number | null = null;
      function handleScroll() {
        if (!pageTopButton) return;

        // 既にrequestAnimationFrameがスケジュールされている場合はスキップ
        if (rafId !== null) return;

        rafId = requestAnimationFrame(() => {
          rafId = null;
          const firstViewBottom = getFirstViewBottom();
          const scrollY = window.scrollY || window.pageYOffset || document.documentElement.scrollTop;

          devLog("📜 Scroll event:", {
            scrollY,
            firstViewBottom,
            shouldShow: scrollY > firstViewBottom,
          });

          // FirstViewを過ぎたかどうかを判定（FirstViewがない場合は300px以上スクロールで表示）
          if (scrollY > firstViewBottom) {
            if (!pageTopButton.classList.contains("is-visible")) {
              devLog("👁️ Showing PageTopButton");
              pageTopButton.classList.add("is-visible");
            }
          } else {
            if (pageTopButton.classList.contains("is-visible")) {
              devLog("🙈 Hiding PageTopButton");
              pageTopButton.classList.remove("is-visible");
            }
          }
        });
      }

      // トップへ戻る処理
      function scrollToTop() {
        devLog("⬆️ Scrolling to top");
        window.scrollTo({
          top: 0,
          behavior: "smooth",
        });
      }

      // イベントリスナーの設定
      scrollHandler = handleScroll;
      clickHandler = scrollToTop;

      window.addEventListener("scroll", scrollHandler, { passive: true });
      pageTopButton.addEventListener("click", clickHandler);

      devLog("✅ Event listeners attached");

      // 初期状態をチェック（少し遅延させてDOMが完全に読み込まれるのを待つ）
      setTimeout(() => {
        handleScroll();
      }, 100);

      // メインスレッド処理の最適化: デバウンスでリサイズイベントの実行頻度を制限
      const debouncedResize = (() => {
        let timeoutId: ReturnType<typeof setTimeout> | null = null;
        return () => {
          if (timeoutId !== null) {
            clearTimeout(timeoutId);
          }
          timeoutId = setTimeout(() => {
            devLog("📐 Window resized, recalculating");
            handleScroll();
          }, 200); // 200msでデバウンス
        };
      })();
      window.addEventListener("resize", debouncedResize, { passive: true });

      isInitialized = true;
    }

    // 初期化関数
    function setupPageTopButton() {
      // DOMが完全に読み込まれるまで待つ
      const checkAndInit = () => {
        const pageTopButton = document.getElementById("pageTopButton");
        if (!pageTopButton) {
          devLog("⏳ PageTopButton not found yet, retrying...");
          setTimeout(checkAndInit, 100);
          return;
        }
        initPageTopButton();
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", checkAndInit);
      } else {
        // 既に読み込まれている場合でも、少し遅延させてから初期化
        setTimeout(checkAndInit, 100);
      }
    }

    // View Transitions対応: ページ遷移時に再初期化
    document.addEventListener("astro:after-swap", () => {
      devLog("🔄 Page swapped, reinitializing");
      cleanup();
      // 少し遅延させてから再初期化（DOMが完全に更新されるのを待つ）
      setTimeout(() => {
        setupPageTopButton();
      }, 200);
    });

    // 初回初期化
    setupPageTopButton();
  })();
</script>
