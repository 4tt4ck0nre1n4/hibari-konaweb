---
import NaviCard from "./NaviCard.astro";
import Glitch from "./Glitch.astro";
// LCP最適化: 画像の最適化はindex.astroで実行（プリロードを最優先配置するため）
// 画像URLはpropsとして受け取る
interface Props {
  fvBackgroundImageSrc: string;
  spFvBackgroundImageSrc: string;
  fvAnimeImageSrc: string;
}

const { fvBackgroundImageSrc, spFvBackgroundImageSrc, fvAnimeImageSrc } = Astro.props;
---

<div class="fv">
  <div class="fv__wrapper">
    <!-- LCP最適化: レスポンシブ画像を<picture>要素で実装 -->
    <!-- 画面幅768px以下はモバイル画像、769px以上（タブレット・デスクトップ）はデスクトップ画像を使用 -->
    <!-- iPad Pro（1024px）などタブレットサイズはデスクトップ用画像を使用 -->
    <!-- width/height属性を追加してレンダリングの遅延を削減（CLS対策も兼ねる） -->
    <picture>
      <!-- モバイル用画像（768px以下・スマホのみ） -->
      <source media="(max-width: 768px)" srcset={spFvBackgroundImageSrc} type="image/webp" width="768" height="432" />
      <!-- デスクトップ用画像（769px以上・タブレット＋デスクトップ） -->
      <source media="(min-width: 769px)" srcset={fvBackgroundImageSrc} type="image/webp" width="1920" height="1080" />
      <!-- フォールバック画像（デスクトップ用を使用） -->
      <img
        src={fvBackgroundImageSrc}
        alt="ファーストビューの背景画像"
        class="fv__background-image"
        width="1920"
        height="1080"
        fetchpriority="high"
        decoding="sync"
        loading="eager"
      />
    </picture>
    <div class="background-container">
      <div class="background-rotated" style={`background-image: url(${fvAnimeImageSrc})`}></div>
      <div class="background"></div>
    </div>
    <h2 class="site-title">My Portfolio Site</h2>
    <div class="glitch-container">
      <NaviCard />
      <Glitch />
    </div>
  </div>
</div>

<style is:global>
  .site-title {
    position: fixed;
    top: 80px;
    right: 168px;
    font-family: "Marcellus", serif;
    font-size: 2rem;
    font-weight: 400;
    color: var(--color-white, #f1f5f9);
    text-shadow:
      0 0 40px rgb(147 51 234 / 0.8),
      0 0 30px rgb(147 51 234 / 0.6),
      0 0 20px rgb(255 255 255 / 0.9),
      0 0 15px rgb(255 255 255 / 0.7),
      0 4px 8px rgb(0 0 0 / 0.5),
      0 2px 4px rgb(0 0 0 / 0.7);
    z-index: 10000;
    pointer-events: none;
    margin: 0;
    white-space: nowrap;
  }

  @media (width <= 850px) {
    .site-title {
      top: 20px;
      left: 50%;
      right: auto;
      transform: translateX(-50%);
      font-size: 1.5rem;
    }
  }
</style>

<script is:inline>
  // @ts-nocheck
  // IIFEでスコープを分離（重複宣言エラーを防ぐ）
  (() => {
    // 開発環境でのみログを出力する関数（重複宣言を防ぐため、既存チェック）
    if (typeof window.devLog === "undefined") {
      window.devLog = (...args) => {
        if (window.__DEV__) {
          console.log(...args);
        }
      };
    }
    if (typeof window.devWarn === "undefined") {
      window.devWarn = (...args) => {
        if (window.__DEV__) {
          console.warn(...args);
        }
      };
    }
    // 重複宣言を避けるため、constで宣言せず、window.devLogを直接使用
    const devLog = typeof window !== "undefined" && window.devLog ? window.devLog : () => {};
    const devWarn = typeof window !== "undefined" && window.devWarn ? window.devWarn : () => {};

    // マウス追従背景の初期化
    function initBackgroundMouseFollow() {
      devLog("🔍 initBackgroundMouseFollow called");

      // 要素が見つかるまで待機（ローディングスクリーンの終了を考慮）
      const checkAndInit = () => {
        devLog("🔍 Checking for elements...");
        const backgroundContainer = document.querySelector(".background-container");
        const fvWrapper = document.querySelector(".fv__wrapper");

        devLog("🔍 Elements found:", { backgroundContainer, fvWrapper });

        if (!backgroundContainer || !fvWrapper) {
          // 要素が見つからない場合は再試行
          devWarn("⚠️ Elements not found, retrying in 100ms...");
          setTimeout(checkAndInit, 100);
          return;
        }

        // ローディングスクリーンの終了を待つ
        const loadingScreen = document.getElementById("loading-screen");
        devLog("🔍 Loading screen:", loadingScreen);

        if (loadingScreen) {
          const checkLoadingComplete = () => {
            // 強制リフローを避けるため、まずインラインスタイルを確認
            const inlineDisplay = loadingScreen.style.display;
            const inlineVisibility = loadingScreen.style.visibility;

            // インラインスタイルで判定可能な場合は、getComputedStyleを呼ばない
            let isVisible = false;
            if (inlineDisplay !== "none" && inlineVisibility !== "hidden") {
              if (inlineDisplay === "" && inlineVisibility === "") {
                // インラインスタイルが設定されていない場合のみ、requestAnimationFrame内でgetComputedStyleを呼ぶ
                requestAnimationFrame(() => {
                  const computedStyle = window.getComputedStyle(loadingScreen);
                  const computedDisplay = computedStyle.display;
                  const computedVisibility = computedStyle.visibility;
                  const computedVisible = computedDisplay !== "none" && computedVisibility !== "hidden";

                  devLog("🔍 Loading screen visible (computed):", computedVisible);

                  if (computedVisible) {
                    // まだローディング中なので再チェック
                    devLog("⏳ Loading screen still visible, rechecking in 100ms...");
                    setTimeout(checkLoadingComplete, 100);
                  } else {
                    // ローディング終了後に初期化
                    devLog("✅ Loading complete, initializing mouse follow...");
                    initializeMouseFollow(backgroundContainer, fvWrapper);
                  }
                });
                return;
              } else {
                isVisible = true;
              }
            }

            devLog("🔍 Loading screen visible (inline):", isVisible);

            if (isVisible) {
              // まだローディング中なので再チェック
              devLog("⏳ Loading screen still visible, rechecking in 100ms...");
              setTimeout(checkLoadingComplete, 100);
            } else {
              // ローディング終了後に初期化
              devLog("✅ Loading complete, initializing mouse follow...");
              initializeMouseFollow(backgroundContainer, fvWrapper);
            }
          };
          checkLoadingComplete();
        } else {
          // ローディングスクリーンが存在しない場合は即座に初期化
          devLog("ℹ️ No loading screen, initializing immediately...");
          initializeMouseFollow(backgroundContainer, fvWrapper);
        }
      };

      checkAndInit();
    }

    // マウス追従の実際の初期化処理
    // グローバルスコープでイベントハンドラーを保持（重複防止のため）
    let mouseMoveHandler = null;
    let mouseLeaveHandler = null;
    let touchStartHandler = null;
    let touchMoveHandler = null;
    let touchEndHandler = null;
    let resizeHandler = null;

    function initializeMouseFollow(backgroundContainer, fvWrapper) {
      // 既存のイベントリスナーを削除（重複防止）
      if (mouseMoveHandler) {
        window.removeEventListener("mousemove", mouseMoveHandler);
        mouseMoveHandler = null;
      }
      if (mouseLeaveHandler) {
        window.removeEventListener("mouseleave", mouseLeaveHandler);
        mouseLeaveHandler = null;
      }
      if (touchStartHandler) {
        window.removeEventListener("touchstart", touchStartHandler);
        touchStartHandler = null;
      }
      if (touchMoveHandler) {
        window.removeEventListener("touchmove", touchMoveHandler);
        touchMoveHandler = null;
      }
      if (touchEndHandler) {
        window.removeEventListener("touchend", touchEndHandler);
        touchEndHandler = null;
      }
      if (resizeHandler) {
        window.removeEventListener("resize", resizeHandler);
        resizeHandler = null;
      }

      // デバッグログ追加（開発環境のみ）
      // 強制リフローを避けるため、requestAnimationFrame内でgetComputedStyleを実行
      requestAnimationFrame(() => {
        devLog("✅ Initializing mouse follow...", {
          backgroundContainer,
          fvWrapper,
          maskImage: window.getComputedStyle(backgroundContainer).maskImage,
          webkitMaskImage: window.getComputedStyle(backgroundContainer).webkitMaskImage,
          mouseXVar: window.getComputedStyle(backgroundContainer).getPropertyValue("--mouse-x"),
          mouseYVar: window.getComputedStyle(backgroundContainer).getPropertyValue("--mouse-y"),
        });
      });

      // パフォーマンス向上のため、requestAnimationFrameを使用
      let rafId = null;
      let mouseX = 0;
      let mouseY = 0;

      // getBoundingClientRectの結果をキャッシュ（メインスレッド処理の最適化）
      let cachedRect = null;
      let lastRectUpdate = 0;
      const RECT_CACHE_DURATION = 100; // 100ms間キャッシュ

      const updateMaskPosition = () => {
        // キャッシュが古い場合のみ再計算
        if (!cachedRect || Date.now() - lastRectUpdate > RECT_CACHE_DURATION) {
          cachedRect = fvWrapper.getBoundingClientRect();
          lastRectUpdate = Date.now();
        }
        const rect = cachedRect;
        const x = mouseX - rect.left;
        const y = mouseY - rect.top;

        // CSS変数を使ってマスクの位置を更新（より確実に設定）
        backgroundContainer.style.setProperty("--mouse-x", `${x}px`);
        backgroundContainer.style.setProperty("--mouse-y", `${y}px`);

        rafId = null;
      };

      // デバイスがタッチデバイスかどうかを判定
      const isTouchDevice =
        window.matchMedia("(any-hover: none)").matches ||
        window.matchMedia("(pointer: coarse)").matches ||
        "ontouchstart" in window;

      devLog("📱 Device type:", isTouchDevice ? "Touch device" : "Desktop");

      // デスクトップ: マウス追従
      if (!isTouchDevice) {
        devLog("🖱️ Setting up desktop mouse tracking...");
        // window全体でマウス移動を監視（画面全体を追従）
        mouseMoveHandler = (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;

          // requestAnimationFrameで更新を最適化
          if (rafId === null) {
            rafId = requestAnimationFrame(updateMaskPosition);
          }
        };
        window.addEventListener("mousemove", mouseMoveHandler, { passive: true });

        devLog("✅ Desktop mouse tracking event listener attached");

        // マウスが画面外に出た場合も追従（画面端でも反応するように）
        mouseLeaveHandler = () => {
          // マウスが画面外に出た場合は最後の位置を保持
        };
        window.addEventListener("mouseleave", mouseLeaveHandler);
      } else {
        // スマホ/タブレット: タッチイベントと自動アニメーションの組み合わせ

        // 1. タッチイベント対応（タッチ位置を追従）
        let touchX = 0;
        let touchY = 0;
        let isTouching = false;

        touchStartHandler = (e) => {
          if (e.touches.length > 0) {
            isTouching = true;
            touchX = e.touches[0].clientX;
            touchY = e.touches[0].clientY;
            mouseX = touchX;
            mouseY = touchY;

            if (rafId === null) {
              rafId = requestAnimationFrame(updateMaskPosition);
            }
          }
        };
        window.addEventListener("touchstart", touchStartHandler, { passive: true });

        touchMoveHandler = (e) => {
          if (e.touches.length > 0 && isTouching) {
            touchX = e.touches[0].clientX;
            touchY = e.touches[0].clientY;
            mouseX = touchX;
            mouseY = touchY;

            if (rafId === null) {
              rafId = requestAnimationFrame(updateMaskPosition);
            }
          }
        };
        window.addEventListener("touchmove", touchMoveHandler, { passive: true });

        touchEndHandler = () => {
          isTouching = false;
        };
        window.addEventListener("touchend", touchEndHandler, { passive: true });

        // 2. 自動アニメーション（タッチ操作がない場合の代替）
        // パルスアニメーション: 定期的に位置を変更して視覚的な動きを提供
        let autoAnimationId = null;
        let animationPhase = 0;
        const animationDuration = 4000; // 4秒周期
        const animationRadius = 100; // 移動半径（px）

        const startAutoAnimation = () => {
          if (autoAnimationId !== null) return; // 既に実行中

          const startTime = Date.now();

          const animate = () => {
            if (isTouching) {
              // タッチ中は自動アニメーションを一時停止
              autoAnimationId = requestAnimationFrame(animate);
              return;
            }

            // 強制リフローを避けるため、getBoundingClientRectの結果をキャッシュ
            // リサイズ時のみ再計算（パフォーマンス最適化）
            if (!cachedRect || Date.now() - lastRectUpdate > 100) {
              cachedRect = fvWrapper.getBoundingClientRect();
              lastRectUpdate = Date.now();
            }
            const rect = cachedRect;
            const centerX = rect.width / 2;
            const centerY = rect.height / 2;

            const elapsed = Date.now() - startTime;
            const progress = (elapsed % animationDuration) / animationDuration;

            // 円形パスで移動（スムーズな動き）
            const angle = progress * Math.PI * 2;
            const offsetX = Math.cos(angle) * animationRadius;
            const offsetY = Math.sin(angle) * animationRadius;

            mouseX = centerX + rect.left + offsetX;
            mouseY = centerY + rect.top + offsetY;

            if (rafId === null) {
              rafId = requestAnimationFrame(updateMaskPosition);
            }

            autoAnimationId = requestAnimationFrame(animate);
          };

          autoAnimationId = requestAnimationFrame(animate);
        };

        // 自動アニメーションを開始（少し遅延させて自然な動きに）
        setTimeout(() => {
          startAutoAnimation();
        }, 500);
      }

      // 初期位置を設定（画面中央）
      // 強制リフローを避けるため、requestAnimationFrame内でgetBoundingClientRectを実行
      const initialX = window.innerWidth / 2;
      const initialY = window.innerHeight / 2;
      requestAnimationFrame(() => {
        // キャッシュを使用（既に設定されている場合）
        if (!cachedRect) {
          cachedRect = fvWrapper.getBoundingClientRect();
          lastRectUpdate = Date.now();
        }
        const rect = cachedRect;
        const x = initialX - rect.left;
        const y = initialY - rect.top;
        backgroundContainer.style.setProperty("--mouse-x", `${x}px`);
        backgroundContainer.style.setProperty("--mouse-y", `${y}px`);

        // 初期化完了のログ（requestAnimationFrame内で実行してスコープ内の変数を使用）
        devLog("✅ Mouse follow initialized successfully", {
          initialX,
          initialY,
          x,
          y,
          rect: {
            left: rect.left,
            top: rect.top,
            width: rect.width,
            height: rect.height,
          },
          // デバッグ情報は別のrequestAnimationFrameで取得して強制リフローを避ける
          finalMouseXVar: window.getComputedStyle(backgroundContainer).getPropertyValue("--mouse-x"),
          finalMouseYVar: window.getComputedStyle(backgroundContainer).getPropertyValue("--mouse-y"),
        });
      });

      // リサイズ時にキャッシュをクリア
      let resizeCacheTimer = null;
      resizeHandler = () => {
        if (resizeCacheTimer) {
          clearTimeout(resizeCacheTimer);
        }
        resizeCacheTimer = setTimeout(() => {
          cachedRect = null;
          lastRectUpdate = 0;
        }, 150);
      };
      window.addEventListener("resize", resizeHandler, { passive: true });
    }

    // LCP最適化: マウス追従の初期化を遅延させずに即座に実行（ローディングスクリーンの待機は最小限に）
    function waitForInit() {
      // ローディングスクリーンの待機を最適化: 最大3000msまで待機（Lighthouse実行時でも確実に初期化されるように）
      const MAX_WAIT_TIME = 3000;
      const startTime = Date.now();

      const tryInit = () => {
        const loadingScreen = document.getElementById("loading-screen");
        const elapsed = Date.now() - startTime;

        // 強制リフローを避けるため、まずインラインスタイルを確認
        // ローディングスクリーンが存在しない、または非表示、または最大待機時間を超えた場合は即座に初期化
        if (
          !loadingScreen ||
          elapsed >= MAX_WAIT_TIME ||
          loadingScreen.style.display === "none" ||
          loadingScreen.style.visibility === "hidden" ||
          loadingScreen.style.opacity === "0"
        ) {
          devLog("✅ Initializing mouse follow (loading screen check passed)");
          initBackgroundMouseFollow();
          return;
        }

        // インラインスタイルで判定できない場合のみ、requestAnimationFrame内でgetComputedStyleを呼ぶ
        if (
          loadingScreen.style.display === "" &&
          loadingScreen.style.visibility === "" &&
          loadingScreen.style.opacity === ""
        ) {
          requestAnimationFrame(() => {
            const computedStyle = window.getComputedStyle(loadingScreen);
            const computedDisplay = computedStyle.display;
            const computedVisibility = computedStyle.visibility;
            const computedOpacity = computedStyle.opacity;

            if (computedDisplay === "none" || computedVisibility === "hidden" || computedOpacity === "0") {
              devLog("✅ Initializing mouse follow (computed style check passed)");
              initBackgroundMouseFollow();
              return;
            }

            // 最大待機時間を超えた場合は強制的に初期化（Lighthouse実行時のフォールバック）
            if (elapsed >= MAX_WAIT_TIME) {
              devWarn("⚠️ Max wait time exceeded, initializing mouse follow anyway");
              initBackgroundMouseFollow();
              return;
            }

            // まだローディング中の場合は再試行
            setTimeout(tryInit, 50);
          });
          return;
        }

        // 最大待機時間を超えた場合は強制的に初期化
        if (elapsed >= MAX_WAIT_TIME) {
          devWarn("⚠️ Max wait time exceeded, initializing mouse follow anyway");
          initBackgroundMouseFollow();
          return;
        }

        // まだローディング中の場合は50ms後に再試行
        setTimeout(tryInit, 50);
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", tryInit);
      } else {
        tryInit();
      }
    }

    // window.onloadイベントでも初期化を試みる（フォールバック）
    window.addEventListener("load", () => {
      waitForInit();
    });

    // 即座にも試行（既に読み込まれている場合）
    waitForInit();

    // View Transitions対応: ページ遷移時に再初期化
    // トップページ（/）に遷移した場合のみマウス追従を初期化
    document.addEventListener("astro:after-swap", () => {
      // 現在のページがトップページかどうかを確認
      if (window.location.pathname === "/" || window.location.pathname === "/index.html") {
        devLog("🔄 Page swapped to index, reinitializing mouse follow...");
        // 少し遅延させてDOMの更新を待つ
        setTimeout(() => {
          waitForInit();
        }, 100);
      }
    });
  })();
</script>
