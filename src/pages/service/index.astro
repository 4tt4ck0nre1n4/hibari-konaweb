---
import Layout from "../../layouts/Layout.astro";
import globalText from "../../data/globalText.json";
import { generateBreadcrumbs } from "../../util/generateBreadcrumbs";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AboutHeading from "../../components/AboutHeading.astro";
import { PricingSimulator } from "../../components/PricingSimulator";
import IconifyInline from "../../components/IconifyInline";
// import Subscription from "../../components/Subscription.astro";

const crumbs = generateBreadcrumbs(Astro.url.pathname);

type ServiceSimulatorCopy = typeof globalText.service & {
  simulatorLeadCardTitle: string;
  simulatorLeadCardSubtitle: string;
  simulatorLeadStepLabels: string[];
  simulatorLeadBenefits: string[];
  simulatorContactNote: string;
  simulatorContactHref?: string;
  simulatorContactLinkLabel: string;
};

const serviceSimulator = globalText.service as ServiceSimulatorCopy;
const stepLabels = serviceSimulator.simulatorLeadStepLabels;
const leadBenefits = serviceSimulator.simulatorLeadBenefits;

---

<Layout
  title={globalText.service.title}
  description={globalText.service.description}
  ogType={globalText.local.type}
  ogTitle={globalText.service.title}
  ogDescription={globalText.service.description}
  twitterTitle={globalText.service.title}
  twitterDescription={globalText.service.description}
>
  <div class="breadcrumbs__wrapper">
    <Breadcrumbs {crumbs} />
  </div>
  <div class="pricePage">
    <div class="subscription-wrapper">
      <!-- <AboutHeading aboutTitle="Service" aboutSubTitle="サービスについて" /> -->
      <!-- <Subscription client:load /> -->
    </div>
    <div class="pricing-simulator-wrapper">
      <div class="service-simulator-page-heading">
        <AboutHeading aboutTitle="Price" aboutSubTitle="料金シミュレーターについて" />
      </div>
      <div class="pricePage__wrapper service-simulator-lead">
        <section class="service-simulator-lead-card" aria-labelledby="simulator-lead-title">
          <h3 id="simulator-lead-title" class="service-simulator-lead-card__title">
            <span class="service-simulator-lead-card__title-icon" aria-hidden="true">
              <IconifyInline client:load icon="emojione:light-bulb" width="1.25em" height="1.25em" />
            </span>
            {serviceSimulator.simulatorLeadCardTitle}
          </h3>
          <p class="service-simulator-lead-card__subtitle">{serviceSimulator.simulatorLeadCardSubtitle}</p>
          <ol class="service-simulator-lead-card__steps">
            {stepLabels.map((label, index) => (
              <li class="service-simulator-lead-card__step">
                <span class="service-simulator-lead-card__step-badge" aria-hidden="true">
                  {index + 1}
                </span>
                {index < 2 ? (
                  <a
                    href="#pricing-simulator"
                    class="service-simulator-lead-card__step-label service-simulator-lead-card__step-label--link"
                  >
                    {label}
                  </a>
                ) : (
                  <span class="service-simulator-lead-card__step-label">{label}</span>
                )}
              </li>
            ))}
          </ol>
          <ul class="service-simulator-lead-card__benefits">
            {leadBenefits.map((text) => (
              <li class="service-simulator-lead-card__benefit">
                <span class="service-simulator-lead-card__check" aria-hidden="true">
                  ✓
                </span>
                {text}
              </li>
            ))}
          </ul>
        </section>
        <p class="service-simulator-lead-footer">
          {serviceSimulator.simulatorContactNote}
          <a
            href={serviceSimulator.simulatorContactHref ?? "/contact"}
            class="price__link service-simulator-lead-footer__link"
          >
            {serviceSimulator.simulatorContactLinkLabel}
          </a>
        </p>
      </div>
      <div id="pricing-simulator"></div>
      <PricingSimulator client:load />
    </div>
  </div>
</Layout>

<style is:global>
  .pricePage {
    margin-block-start: 1rem;
    padding-block: 1rem;
  }
  .pricePage__wrapper {
    width: 100%;
    max-width: 700px;
    margin-inline: auto;
  }
  @media (width <= 768px) {
    .pricePage__wrapper {
      width: 90%;
    }
  }
  @media (width <= 480px) {
    .pricePage__wrapper {
      width: 80%;
    }
  }
  .price__body {
    font-size: 1rem;
    line-height: 2;
    letter-spacing: 0.1em;
    color: inherit;
    text-align: center;
    margin-block-start: 1rem;
  }
  @media (width <= 768px) {
    .price__body {
      font-size: 0.9375rem;
      line-height: 1.8;
      letter-spacing: 0.04em;
      text-align: left;
    }
  }
  .price__body:last-child {
    text-align: center;
    margin-block-start: 2rem;
  }
  .price__image {
    width: 200px;
    height: 200px;
    border-radius: 20%;
    object-fit: contain;
    margin-block-start: 1rem;
    margin-inline: auto;
    padding-block: 1rem;
    padding-inline: 1rem;
    animation: movingCat 2s alternate infinite;
  }
  /* ダークモード時に猫の体を白色にする */
  html.dark .price__image {
    background-color: var(--color-white);
  }
  @keyframes movingCat {
    0% {
      transform: translateY(0) translateZ(0);
    }
    100% {
      transform: translateY(-10px) translateZ(16px);
    }
  }
  .price__link {
    letter-spacing: 0.1em;
    color: var(--color-purple);
    text-align: center;
    text-decoration: underline;
    margin-block-start: 1rem;
  }
  .price__link_secondary {
    letter-spacing: 0.1em;
    color: var(--color-purple);
    text-align: center;
    text-decoration: underline;
    margin-block-start: 1rem;
    padding-block: 1rem;
  }
  .price__link:is(:hover, :focus-within) {
    color: var(--color-red);
    text-decoration: none;
  }
  .price__link_secondary:is(:hover, :focus-within) {
    color: var(--color-red);
    text-decoration: none;
  }

  /* 概算見積書ビュー時：見出し・リードを非表示 — PricingSimulator が data-estimate-view を付与 */
  html[data-estimate-view="true"] .service-simulator-page-heading,
  html[data-estimate-view="true"] .service-simulator-lead {
    display: none !important;
  }

  /* 料金シミュレーター前リードカード */
  .service-simulator-lead {
    /* text-align: center; */
  }

  .service-simulator-lead-card {
    color: #166534;
    background-color: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 1rem;
    text-align: center;
    word-break: keep-all;
    overflow-wrap: break-word;
    margin-block-start: 2rem;
    padding-block: 1.5rem;
    padding-inline: 1.5rem;
  }

  html.dark .service-simulator-lead-card {
    background-color: #052e16;
    border-color: #14532d;
    color: #bbf7d0;
  }

  .service-simulator-lead-card__title {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: 0.06em;
    color: inherit;
    margin: 0;
  }

  .service-simulator-lead-card__title-icon {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }

  .service-simulator-lead-card__subtitle {
    max-width: 36rem;
    font-size: 1rem;
    line-height: 1.75;
    letter-spacing: 0.06em;
    color: color-mix(in srgb, currentColor 72%, transparent);
    margin-block-start: 0.75rem;
    margin-block-end: 1.25rem;
    margin-inline: auto;
  }

  .service-simulator-lead-card__steps {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.625rem 0.75rem;
  }

  .service-simulator-lead-card__step {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background-color: color-mix(in srgb, currentColor 6%, transparent);
    border-radius: 624.9375rem;
    font-size: 0.875rem;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    line-height: 1.5;
    min-inline-size: 0;
    padding-block: 0.5rem;
    padding-inline: 1rem;
  }

  .service-simulator-lead-card__step-badge {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: 1.75rem;
    block-size: 1.75rem;
    font-size: 0.875rem;
    font-weight: 700;
    line-height: 1;
    color: var(--color-white, #f1f5f9);
    background-color: var(--color-purple, #8b5cf6);
    border-radius: 50%;
  }

  .service-simulator-lead-card__step-label {
    color: inherit;
  }

  .service-simulator-lead-card__step-label--link {
    color: inherit;
    /* text-decoration: underline; */
    text-underline-offset: 0.2em;
    text-decoration-color: color-mix(in srgb, currentColor 40%, transparent);
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .service-simulator-lead-card__step-label--link:is(:hover, :focus-visible) {
    opacity: 0.75;
    text-decoration-color: currentColor;
  }

  .service-simulator-lead-card__benefits {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 1.25rem;
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    line-height: 1.5;
    color: var(--color-purple, #639);
    margin-block-start: 1.25rem;
    margin-block-end: 0;
  }

  .service-simulator-lead-card__benefit {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .service-simulator-lead-card__check {
    font-weight: 700;
  }

  .service-simulator-lead-footer {
    font-size: 1rem;
    line-height: 1.75;
    letter-spacing: 0.06em;
    text-align: center;
    color: inherit;
    margin-block-start: 1rem;
  }

  .service-simulator-lead-footer__link {
    margin-inline-start: 0.15em;
    margin-block-start: 0;
    text-align: inherit;
    display: inline;
  }

  @media (width <= 768px) {
    .service-simulator-lead-card {
      padding-block: 1.25rem;
      padding-inline: 1.125rem;
    }

    .service-simulator-lead-card__steps {
      flex-direction: column;
      align-items: center;
    }

    .service-simulator-lead-card__step {
      justify-content: center;
      inline-size: 100%;
      max-width: 20rem;
    }

    .service-simulator-lead-card__benefits {
      flex-direction: column;
      align-items: center;
      gap: 0.35rem;
    }
  }

  /* 印刷時のスタイル */
  @media print {
    .service-simulator-lead {
      display: none !important;
      visibility: hidden !important;
      opacity: 0 !important;
      height: 0 !important;
      margin: 0 !important;
      padding: 0 !important;
      overflow: hidden !important;
    }
    .about-heading,
    .about__title,
    .about__subTitle,
    hgroup,
    .pricePage__wrapper > .price__body,
    .pricePage__wrapper > .price__image {
      display: none !important;
      visibility: hidden !important;
      opacity: 0 !important;
      height: 0 !important;
      margin: 0 !important;
      padding: 0 !important;
      overflow: hidden !important;
    }
  }
</style>

<script>
  import Swiper from "swiper";
  import { Navigation, Autoplay } from "swiper/modules";
  import "swiper/css/bundle";

  const initSwiper2 = () => {
    // フェーズ1: DOM読み取りを実行（可能な限り事前に読み取る）
    const swiperElement = document.querySelector("#swiper2");
    if (!swiperElement) return;

    new Swiper("#swiper2", {
      direction: "horizontal",
      modules: [Navigation, Autoplay],
      loop: true,
      effect: "fade",
      speed: 0,
      allowTouchMove: false,
      autoplay: {
        delay: 3000,
        disableOnInteraction: false,
      },
      navigation: {
        nextEl: "#js-mouse",
      },
      on: {
        slideChangeTransitionStart: function () {
          // フェーズ1: すべてのDOM読み取りを一度に実行
          const allImages = document.querySelectorAll(".swiper-slide img");

          // フェーズ2: すべての書き込みを一度に実行（リフローを最小化）
          requestAnimationFrame(() => {
            allImages.forEach((img) => {
              img.classList.remove("active");
            });
          });
        },
        slideChangeTransitionEnd: function () {
          // フェーズ1: DOM読み取りを実行
          const activeSlide = document.querySelector(".swiper-slide-active img");

          // フェーズ2: 書き込みを実行（リフローを最小化）
          if (activeSlide) {
            requestAnimationFrame(() => {
              activeSlide.classList.add("active");
            });
          }
        },
      },
    });
  };

  if (typeof window !== "undefined") {
    initSwiper2();
  }
</script>
