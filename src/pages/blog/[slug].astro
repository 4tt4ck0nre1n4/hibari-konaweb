---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import globalText from "../../data/globalText.json";
import { github_sns, twitter } from "../../data/constSns";
import { BLOG_PAGE_API, BLOG_SLUG_API } from "../../api/headlessCms";
import SafeIcon from "../../components/SafeIcon.astro";
import { blogPostsResponseSchema, type BlogPost } from "../../schemas/api.schema";
import { validateApiResponse } from "../../schemas/api.schema";
import { getWordPressImageUrl } from "../../util/optimizeWordPressImage";
import "../../styles/blog-article.css";

function stripHtml(html: string): string {
  return html
    .replace(/<[^>]*>/g, "")
    .replace(/&nbsp;/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

const dateIcon = {
  icon: "emojione-v1:alarm-clock",
  width: 24,
  height: 24,
};

const categoryIcon = {
  icon: "emojione-v1:bookmark",
  width: 24,
  height: 24,
};

const shareIconSize = 18;

export { getBlogSlugStaticPaths as getStaticPaths } from "../../api/blogPostsBuild";

const { slug } = Astro.params;
let post: BlogPost | undefined;

async function fetchWithRetry(url: string, retries = 3, delay = 1000): Promise<Response> {
  for (let i = 0; i < retries; i++) {
    try {
      const response = await fetch(url);

      if (response.status >= 500 && i < retries - 1) {
        console.warn(`Server error ${response.status}, retrying... (${i + 1}/${retries})`);
        await new Promise((resolve) => setTimeout(resolve, delay * (i + 1)));
        continue;
      }

      return response;
    } catch (error) {
      if (i < retries - 1) {
        console.warn(`Fetch failed, retrying... (${i + 1}/${retries})`, error);
        await new Promise((resolve) => setTimeout(resolve, delay * (i + 1)));
        continue;
      }
      throw error;
    }
  }
  throw new Error("Max retries reached");
}

try {
  console.log(`Fetching blog post data for slug: ${slug}`);

  const resPosts = await fetchWithRetry(`${BLOG_SLUG_API}${slug}`);

  if (!resPosts.ok) {
    console.error(`Failed to fetch post data for slug "${slug}": ${resPosts.status} ${resPosts.statusText}`);
    throw new Error(`Failed to fetch post data: ${resPosts.status}`);
  }

  const json = await resPosts.json();
  const dataPosts = validateApiResponse(blogPostsResponseSchema, json, "Blog Post Slug API", [] as BlogPost[]);

  if (dataPosts.length === 0) {
    console.error("No Post data found for slug:", slug);
    throw new Error("Post not found");
  }

  post = dataPosts[0];
} catch (error) {
  console.error("Error fetching post data:", error);
  throw new Error("Post not found");
}

let sidebarPosts: BlogPost[] = [];
try {
  const resList = await fetchWithRetry(BLOG_PAGE_API);
  if (resList.ok) {
    const jsonList = await resList.json();
    const allPosts = validateApiResponse(blogPostsResponseSchema, jsonList, "Blog page list for sidebar", [] as BlogPost[]);
    sidebarPosts = allPosts.filter((p) => p.slug !== slug).slice(0, 4);
  }
} catch (e) {
  console.warn("Sidebar posts fetch failed:", e);
}

const postId = post?.id ?? 0;
const postSlugTitle = post?.title?.rendered;
const title = post?.title?.rendered ?? "記事が見つかりません";
const plainTitle = stripHtml(title);
const publishedDate = typeof post?.date === "string" && post.date !== "" ? new Date(post.date).toISOString() : "";
const postDate = post?.date ?? "";
const content = post?.content?.rendered ?? "この記事の内容は表示できません";
const postUrl = `${globalText.url}/blog/${post?.slug}`;
const errorCategoryText = "カテゴリーが見つかりませんでした。";
const datetime = "投稿日:";
const categoryLabel = "カテゴリー:";
const categoryAriaLabel = "のカテゴリー記事へ";
const categoryAriaTitle = "のカテゴリー記事へ";
export const prerender = true;

const acfDescription: string = typeof post?.acf?.description === "string" ? post.acf.description : "";
const postMetaDescription = acfDescription.trim();
const jsonLdDescription = acfDescription.replace(/(<([^>]+)>)/gi, "").trim();

const siteBase = globalText.url.replace(/\/$/, "");
const contactUrl = `${siteBase}/contact`;
const worksUrl = `${siteBase}/works`;
const serviceUrl = `${siteBase}/service`;
const aboutUrl = `${siteBase}/about`;

const authorName = globalText.global.author;
const profileBio =
  "クリエイティビティ × AI × ビジネス。成果に直結するWebサイトやアプリケーションを制作しています。Astro / React 等が得意です。";
const profileTagline = "フロントエンドエンジニア / デザイナー";
const profileAvatarUrl = `https://ui-avatars.com/api/?name=${encodeURIComponent(authorName)}&background=4f46e5&color=fff&size=150`;

const layoutTitle = plainTitle !== "" ? plainTitle : "Blog Title Not Found";
const jsonLdHeadline = plainTitle !== "" ? plainTitle : "Blog post";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: jsonLdHeadline,
  description: jsonLdDescription,
  datePublished: publishedDate,
  url: `${globalText.url}/blog/${post?.slug}`,
  author: {
    "@type": "Person",
    name: `${globalText.global.author}`,
  },
  image: getWordPressImageUrl(post?.acf?.blog_image) ?? "",
});

const crumbs = [{ name: "Home", path: "/" }, { name: "Blog", path: "/blog" }, { name: postSlugTitle }];
---

<Layout
  title={layoutTitle}
  description={postMetaDescription}
  ogType={globalText.local.type}
  ogTitle={layoutTitle}
  ogDescription={postMetaDescription}
  twitterTitle={layoutTitle}
  twitterDescription={postMetaDescription}
  jsonLd={jsonLd}
>
  <div class="breadcrumbs__wrapper">
    <Breadcrumbs {crumbs} />
  </div>

  <div class="max-w-6xl mx-auto px-4 pb-16 flex flex-col lg:flex-row gap-8">
    <main class="w-full lg:w-2/3">
      <article id={postId.toString()} class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 md:p-10">
        <header class="mb-8 border-b border-slate-100 pb-8">
          <h1 class="text-2xl md:text-3xl font-bold leading-tight mb-4 text-slate-900" set:html={title} />
          <div class="flex flex-wrap items-center text-sm text-slate-500 gap-4">
            <div class="flex items-center gap-1">
              <SafeIcon name={dateIcon.icon} width={dateIcon.width} height={dateIcon.height} />
              <span class="screenReader-only">{datetime}</span>
              {
                postDate !== "" && (
                  <time
                    datetime={new Date(postDate)
                      .toLocaleDateString("ja-JP", {
                        year: "numeric",
                        month: "2-digit",
                        day: "2-digit",
                      })
                      .replaceAll("/", "-")}
                  >
                    {new Date(postDate).toLocaleDateString("ja-JP", {
                      year: "numeric",
                      month: "2-digit",
                      day: "2-digit",
                    })}
                  </time>
                )
              }
            </div>
            <div class="flex items-center">
              {
                Array.isArray(post?.cat_info) && post.cat_info.length > 0 ? (
                  <a
                    class="inline-flex items-center gap-1 no-underline text-inherit hover:opacity-80 transition-opacity"
                    href={`/blog/category/${decodeURIComponent(post.cat_info[0]?.slug ?? "")}`}
                    aria-label={`${post.cat_info[0]?.name}${categoryAriaLabel}`}
                    title={`${post.cat_info[0]?.name}${categoryAriaTitle}`}
                  >
                    <SafeIcon name={categoryIcon.icon} width={categoryIcon.width} height={categoryIcon.height} />
                    <span class="screenReader-only">{categoryLabel}</span>
                    <span>{post.cat_info[0]?.name}</span>
                  </a>
                ) : (
                  <span>{errorCategoryText}</span>
                )
              }
            </div>
          </div>
        </header>

        <div class="blog-article-content" set:html={content} />

        <div class="flex items-center justify-between py-6 border-t border-b border-slate-100 mb-10">
          <span class="text-sm font-bold text-slate-400">記事をシェアする</span>
          <div class="flex gap-3">
            <a
              href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(postUrl)}&text=${encodeURIComponent(plainTitle)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 flex items-center justify-center rounded-full bg-slate-100 text-slate-600 hover:bg-[#1DA1F2] hover:text-white transition-colors duration-200"
              aria-label="X (Twitter)でシェア"
            >
              <SafeIcon name="fa6-brands:x-twitter" width={shareIconSize} height={shareIconSize} ariaHidden={true} />
            </a>
            <a
              href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(postUrl)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 flex items-center justify-center rounded-full bg-slate-100 text-slate-600 hover:bg-[#1877F2] hover:text-white transition-colors duration-200"
              aria-label="Facebookでシェア"
            >
              <SafeIcon name="fa6-brands:facebook-f" width={shareIconSize} height={shareIconSize} ariaHidden={true} />
            </a>
            <a
              href={`https://b.hatena.ne.jp/add?mode=confirm&url=${encodeURIComponent(postUrl)}&title=${encodeURIComponent(plainTitle)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 flex items-center justify-center rounded-full bg-slate-100 text-slate-600 hover:bg-[#00A4DE] hover:text-white transition-colors duration-200 font-bold font-serif leading-none text-sm"
              aria-label="はてなブックマークに追加"
            >
              B!
            </a>
          </div>
        </div>

        <div
          class="bg-linear-to-br from-indigo-50 to-blue-50 rounded-xl p-8 border border-indigo-100 text-center relative overflow-hidden"
        >
          <div class="absolute -right-6 -top-6 text-indigo-100 opacity-50 pointer-events-none" aria-hidden="true">
            <SafeIcon name="fa6-solid:paper-plane" width={120} height={120} ariaHidden={true} />
          </div>

          <div class="relative z-10">
            <span class="inline-block px-3 py-1 bg-primary text-white text-xs font-bold rounded-full mb-4">
              Web制作・システム開発のご相談
            </span>
            <h2 class="text-xl md:text-2xl font-bold text-slate-900 mb-3">
              あなたのビジネス課題をWebで解決しませんか？
            </h2>
            <p class="text-sm md:text-base text-slate-600 mb-6 max-w-lg mx-auto">
              この記事で紹介した技術を用いたサイト構築や、現状のWebサイトの改善提案を行っています。まずは無料でお気軽にご相談ください。
            </p>

            <div class="flex flex-col sm:flex-row justify-center gap-4">
              <a
                href={contactUrl}
                class="inline-flex items-center justify-center px-6 py-3 bg-primary text-white font-bold rounded-lg hover:bg-indigo-700 transition-colors shadow-md hover:shadow-lg"
              >
                <SafeIcon name="fa6-solid:envelope" width={18} height={18} class="mr-2 shrink-0" ariaHidden={true} />
                無料相談・お問い合わせ
              </a>
              <a
                href={worksUrl}
                class="inline-flex items-center justify-center px-6 py-3 bg-white text-primary font-bold rounded-lg border border-primary hover:bg-slate-50 transition-colors"
              >
                <SafeIcon name="fa6-solid:desktop" width={18} height={18} class="mr-2 shrink-0" ariaHidden={true} />
                制作実績を見る
              </a>
            </div>
          </div>
        </div>
      </article>
    </main>

    <aside class="w-full lg:w-1/3 space-y-6">
      <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 text-center">
        <div class="w-24 h-24 mx-auto rounded-full bg-slate-200 mb-4 overflow-hidden border-4 border-slate-50">
          <img
            src={profileAvatarUrl}
            alt=""
            width={150}
            height={150}
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
        <h3 class="text-lg font-bold text-slate-900 mb-1">{authorName}</h3>
        <p class="text-xs text-primary font-bold mb-4">{profileTagline}</p>
        <p class="text-sm text-slate-600 text-left mb-4 leading-relaxed">
          {profileBio}
        </p>
        <div class="flex justify-center gap-3 border-t border-slate-100 pt-4">
          <a
            href={github_sns.href}
            target={github_sns.targetBlank}
            rel="noopener noreferrer"
            class="text-slate-400 hover:text-slate-600"
            aria-label={github_sns.ariaLabel}
          >
            <SafeIcon name="bi:github" width={22} height={22} ariaHidden={true} />
          </a>
          <a
            href={twitter.href}
            target={twitter.targetBlank}
            rel="noopener noreferrer"
            class="text-slate-400 hover:text-[#1DA1F2]"
            aria-label={twitter.ariaLabel}
          >
            <SafeIcon name="devicon:twitter" width={22} height={22} ariaHidden={true} />
          </a>
          <a href={aboutUrl} class="text-slate-400 hover:text-slate-600" aria-label="サイトについて">
            <SafeIcon name="fa6-solid:link" width={22} height={22} ariaHidden={true} />
          </a>
        </div>
      </div>

      <a
        href={serviceUrl}
        class="block bg-slate-800 text-white rounded-xl shadow-sm overflow-hidden hover:opacity-95 transition-opacity group relative"
      >
        <div class="p-6 relative z-10">
          <div class="text-secondary text-xs font-bold mb-2">おすすめパッケージ</div>
          <h3 class="text-lg font-bold mb-2">
            月額5500円<br />
            サブスクリプション型ホームページ制作
          </h3>
          <p class="text-xs text-slate-300 mb-4">Astro + Headless CMSで保守性の高いモダンなサイトを構築します。</p>
          <div class="inline-flex items-center text-sm font-bold text-white group-hover:translate-x-1 transition-transform">
            詳細を見る
            <SafeIcon name="fa6-solid:arrow-right" width={16} height={16} class="ml-2 text-secondary shrink-0" ariaHidden={true} />
          </div>
        </div>
        <div class="absolute -bottom-10 -right-10 text-slate-700 opacity-30 transform rotate-12 pointer-events-none" aria-hidden="true">
          <SafeIcon name="fa6-solid:rocket" width={180} height={180} ariaHidden={true} />
        </div>
      </a>

      <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6">
        <h3 class="text-sm font-bold text-slate-900 mb-4 flex items-center border-b border-slate-100 pb-2">
          <SafeIcon name="fa6-solid:crown" width={18} height={18} class="text-yellow-400 mr-2 shrink-0" ariaHidden={true} />
          読まれている記事
        </h3>
        <ul class="space-y-4">
          {
            sidebarPosts.map((p) => {
              const thumb = getWordPressImageUrl(p.acf?.blog_image);
              const itemTitle = p.title?.rendered ?? "";
              return (
                <li>
                  <a href={`/blog/${p.slug}`} class="group flex items-start gap-3 no-underline">
                    <div class="w-16 h-12 bg-slate-100 rounded shrink-0 border border-slate-200 overflow-hidden flex items-center justify-center">
                      {thumb !== null && thumb !== "" ? (
                        <Image
                          src={thumb}
                          alt=""
                          width={64}
                          height={48}
                          class="w-full h-full object-cover"
                          loading="lazy"
                        />
                      ) : null}
                    </div>
                    <div class="min-w-0">
                      <h4
                        class="text-sm font-bold text-slate-700 group-hover:text-primary transition-colors line-clamp-2 leading-tight"
                        set:html={itemTitle}
                      />
                    </div>
                  </a>
                </li>
              );
            })
          }
        </ul>
      </div>
    </aside>
  </div>
</Layout>
