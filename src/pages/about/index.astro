      pointer-events: auto;
      -webkit-touch-callout: none;
      -webkit-user-select: none;
      user-select: none;
    }
  }
</style>

<script>
  import { setupFlowingLinesAnimation } from "../../scripts/flowingLines";
  setupFlowingLinesAnimation();

  // タッチデバイスでのスキルアイコンのアニメーション制御
  function setupTouchAnimations() {
    // タッチデバイスのみで実行
    if (window.matchMedia("(any-hover: none)").matches) {
      const skillIcons = document.querySelectorAll(".skills-icon");

      skillIcons.forEach((icon) => {
        const image = icon.querySelector(".skills-icon__image");

        if (image) {
          // タッチ開始
          icon.addEventListener(
            "touchstart",
            (e) => {
              e.preventDefault();
              image.classList.add("touch-animate");
              icon.classList.add("touch-active");
            },
            { passive: false }
          );

          // タッチ終了
          icon.addEventListener(
            "touchend",
            (e) => {
              e.preventDefault();

              // アニメーションを実行
              setTimeout(() => {
                image.classList.remove("touch-animate");
                icon.classList.remove("touch-active");
              }, 300); // アニメーション時間に合わせて
            },
            { passive: false }
          );

          // タッチキャンセル（スクロールなどで中断された場合）
          icon.addEventListener(
            "touchcancel",
            (e) => {
              e.preventDefault();
              image.classList.remove("touch-animate");
              icon.classList.remove("touch-active");
            },
            { passive: false }
          );
        }
      });
    }
  }

  // スクロール検知とアニメーション制御
  function setupScrollAnimation() {
    const aboutImageInner = document.querySelector(".about__imageInner");

    if (!aboutImageInner) return;

    // アニメーション中かどうかを管理するフラグ
    let isAnimating = false;

    // Intersection Observer の設定
    const observerOptions = {
      threshold: 0.3, // 要素の30%が見えたら発火
      rootMargin: "0px 0px -50px 0px", // 少し早めに発火させる
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting && !isAnimating) {
          // アニメーション開始
          isAnimating = true;
          aboutImageInner.classList.add("animate");

          // 2秒後にアニメーションをリセット（消える）
          setTimeout(() => {
            aboutImageInner.classList.remove("animate");
            isAnimating = false;
          }, 2000);
        }
      });
    }, observerOptions);

    // 要素の監視を開始
    observer.observe(aboutImageInner);
  }

  // スキルアイコンの順次表示アニメーション
  function setupSkillsIconAnimation() {
    const skillsMenu = document.querySelector(".skills__menu");

    if (!skillsMenu) return;

    // タイムアウトIDを管理する配列
    let timeoutIds: number[] = [];

    // すべてのスキルアイコンの画像を取得する関数
    const getSkillImages = () => {
      const skillIcons = skillsMenu.querySelectorAll(".skills-icon");
      return Array.from(skillIcons)
        .map((icon) => icon.querySelector(".skills-icon__image[data-icon]"))
        .filter((image): image is Element => image !== null);
    };

    // アニメーションをリセットする関数
    const resetAnimation = () => {
      // 実行中のタイムアウトをすべてクリア
      timeoutIds.forEach((id) => clearTimeout(id));
      timeoutIds = [];

      // すべての画像からshowクラスを削除
      const skillImages = getSkillImages();
      skillImages.forEach((image) => {
        image.classList.remove("show");
      });
    };

    // アニメーションを実行する関数
    const runAnimation = () => {
      // 既存のタイムアウトをクリア
      timeoutIds.forEach((id) => clearTimeout(id));
      timeoutIds = [];

      const skillImages = getSkillImages();

      // 各画像を0.2秒ずつ遅らせながら順番に表示
      skillImages.forEach((image, index) => {
        const timeoutId = window.setTimeout(() => {
          image.classList.add("show");
        }, index * 200); // 0.2秒 = 200ms
        timeoutIds.push(timeoutId);
      });
    };

    // Intersection Observer の設定
    const observerOptions = {
      threshold: 0.2, // 要素の20%が見えたら発火
      rootMargin: "0px 0px -50px 0px", // 少し早めに発火させる
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          // ビューポートに入ったらアニメーションを実行
          runAnimation();
        } else {
          // ビューポートから出たらアニメーションをリセット
          resetAnimation();
        }
      });
    }, observerOptions);

    // 要素の監視を開始
    observer.observe(skillsMenu);
  }

  // DOM読み込み完了後に実行（View Transitions対応）
  function initializeAnimations() {
    setupTouchAnimations();
    setupScrollAnimation();
    setupSkillsIconAnimation();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeAnimations);
  } else {
    initializeAnimations();
  }

  // View Transitions対応: ページ遷移時にも再初期化
  document.addEventListener("astro:after-swap", () => {
    initializeAnimations();
  });
</script>
